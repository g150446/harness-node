/*
 * Device Tree Overlay for Voice Bridge BLE
 * PDM Microphone on XIAO nRF54L15 Sense
 * PDM_CLK: P1.06 (D2), PDM_DATA: P1.07 (D3)
 */

&pinctrl {
	pdm20_default_alt: pdm20_default_alt {
		group1 {
			psels = <NRF_PSEL(PDM_CLK, 1, 6)>,
				<NRF_PSEL(PDM_DIN, 1, 7)>;
		};
	};
};

dmic_dev: &pdm20 {
	status = "okay";
	pinctrl-0 = <&pdm20_default_alt>;
	pinctrl-names = "default";
	clock-source = "PCLK32M";
};
