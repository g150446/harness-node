/*
 * Device Tree Overlay for Seeed Studio XIAO nRF52840 Sense
 * nordic-main: PDM microphone + flash partitions (no IMU)
 *
 * Partition DTS ID assignment (sorted by address):
 *   0x00000 sd_partition        → 0  (board DTS)
 *   0x27000 code_partition      → 1  (board DTS)
 *   0x2f000 mcuboot_pad_part   → 2  = PM_MCUBOOT_PAD_ID(2)
 *   0x33000 slot0_partition     → 3  = PM_MCUBOOT_PRIMARY_ID(3) ← MCUmgr slot0
 *   0x33200 app_part            → 4  = PM_APP_ID(4)
 *   0x34000 primary_app_part    → 5  = PM_MCUBOOT_PRIMARY_APP(5)
 *   0x85000 slot1_partition     → 6  = PM_MCUBOOT_SECONDARY_ID(6) ← MCUmgr slot1
 *   0xec000 storage_partition   → 7  = PM_SETTINGS_STORAGE_ID(7) (board DTS)
 *   0xf4000 boot_partition      → 8  = PM_ADAFRUIT_BOOT_ID(8)    (board DTS)
 */

/ {
    aliases {
        dmic0 = &pdm0;
        imu0 = &lsm6ds3tr_c;
    };

    /* Enable microphone power at boot (P1.10 — not enabled by board DTS by default) */
    msm261d3526hicpm_c_en: msm261d3526hicpm-c-en {
        compatible = "regulator-fixed-sync", "regulator-fixed";
        enable-gpios = <&gpio1 10 (NRF_GPIO_DRIVE_S0H1 | GPIO_ACTIVE_HIGH)>;
        regulator-name = "MSM261D3526HICPM-C-EN";
    };
};

&pinctrl {
    pdm0_default_alt: pdm0_default_alt {
        group1 {
            psels = <NRF_PSEL(PDM_CLK, 1, 0)>,   /* P1.00 */
                    <NRF_PSEL(PDM_DIN, 0, 16)>;   /* P0.16 */
        };
    };

    pdm0_sleep_alt: pdm0_sleep_alt {
        group1 {
            psels = <NRF_PSEL(PDM_CLK, 1, 0)>,
                    <NRF_PSEL(PDM_DIN, 0, 16)>;
            low-power-enable;
        };
    };
};

&pdm0 {
    status = "okay";
    pinctrl-0 = <&pdm0_default_alt>;
    pinctrl-1 = <&pdm0_sleep_alt>;
    pinctrl-names = "default", "sleep";
};

/ {
    zephyr,user {
        /* P0.31 = AIN7 — actual battery voltage ADC input (1/2 divider) */
        io-channels = <&adc 7>;
        /* P0.14 = battery measurement enable (set HIGH before reading) */
        bat-read-enable-gpios = <&gpio0 14 GPIO_ACTIVE_HIGH>;
    };
};

&adc {
    status = "okay";
    #address-cells = <1>;
    #size-cells = <0>;

    channel@7 {
        reg = <7>;
        zephyr,gain = "ADC_GAIN_1_6";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,input-positive = <NRF_SAADC_AIN7>; /* P0.31 */
        zephyr,resolution = <12>;
        zephyr,oversampling = <4>;
    };
};

&flash0 {
    partitions {
        /* ID 2 — matches PM_MCUBOOT_PAD_ID = 2 */
        mcuboot_pad_part: partition@2f000 {
            label = "mcuboot-pad";
            reg = <0x2f000 0x200>;
        };

        /* ID 3 — matches PM_MCUBOOT_PRIMARY_ID = 3 → used by MCUmgr as slot 0 */
        slot0_partition: partition@33000 {
            label = "image-0";
            reg = <0x33000 0x52000>;
        };

        /* ID 4 — matches PM_APP_ID = 4 */
        app_part: partition@33200 {
            label = "app";
            reg = <0x33200 0x51e00>;
        };

        /* ID 5 — matches PM_MCUBOOT_PRIMARY_APP_ID = 5 */
        primary_app_part: partition@34000 {
            label = "mcuboot-primary-app";
            reg = <0x34000 0x51000>;
        };

        /* ID 6 — matches PM_MCUBOOT_SECONDARY_ID = 6 → used by MCUmgr as slot 1 */
        slot1_partition: partition@85000 {
            label = "image-1";
            reg = <0x85000 0x52000>;
        };
    };
};
